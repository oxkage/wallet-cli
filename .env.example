# --- Required ---

# Seed phrase for the burner wallet HD derivation (BIP-39, 12/24 words).
SEED_PHRASE="word1 word2 word3 ... word12"

# Alchemy API key. ONE key powers RPC for every supported chain — the CLI
# builds each chain's endpoint as https://<network>.g.alchemy.com/v2/<KEY>.
# Chains Alchemy doesn't serve fall back to a bundled public RPC automatically.
# Get a key at https://dashboard.alchemy.com (free tier is plenty).
ALCHEMY_API_KEY="your-alchemy-key"

# --- Optional ---

# Path to an external wallet source file (relative or absolute).
BURNER_WALLETS_FILE="/absolute/or/relative/path/to/wallets.json"

# Logging level: info | warn | error | debug
LOG_LEVEL="info"
